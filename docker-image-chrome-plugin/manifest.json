{
  "manifest_version": 3,
  "name": "Docker Image One-Click Downloader",
  "version": "1.0.0",
  "description": "Directly download a Docker image of a specific architecture from the Docker Hub image page",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "https://hub.docker.com/*",
    "http://ip-api.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background-wrapper.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://hub.docker.com/r/*/*",
        "https://hub.docker.com/_/*",
        "https://hub.docker.com/r/*/tags*",
        "https://hub.docker.com/_/*/tags*",
        "https://hub.docker.com/*/tags*",
        "https://hub.docker.com/r/*/*/tags*",
        "https://hub.docker.com/*/"
      ],
      "js": [
        "config.js",
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
